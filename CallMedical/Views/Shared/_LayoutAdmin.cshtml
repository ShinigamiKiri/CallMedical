<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - CallMedical Admin Panel</title>
    <style>
        :root {
            --primary: #63B8FF;
            --white: #ffffff;
            --dark: #1a1a2e;
            --dark-light: #252545;
            --text-gray: #cccccc;
            --text-light: #ffffff;
            --bg-body: #f4f7f6;
            --sidebar-width: 260px;
            --header-height: 60px;
            --font-main: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-main);
            background-color: var(--bg-body);
            color: #333;
        }

        /* Header Styles */
        .header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: var(--header-height);
            background-color: var(--dark);
            color: var(--white);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
            z-index: 1000;
            border-bottom: 2px solid var(--primary);
        }

        .header__left {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .header__hamburger {
            font-size: 1.5rem;
            cursor: pointer;
            display: block;
        }

        .header__logo-text {
            font-size: 1.3rem;
            font-weight: bold;
            letter-spacing: 0.5px;
        }

        .header__right {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .header__admin-info {
            display: none;
            align-items: center;
            gap: 10px;
        }

        .header__avatar {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            background-color: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

        /* Sidebar Styles */
        .sidebar {
            position: fixed;
            top: var(--header-height);
            left: -var(--sidebar-width);
            width: var(--sidebar-width);
            height: calc(100vh - var(--header-height));
            background-color: var(--dark);
            transition: left 0.3s ease;
            z-index: 900;
            overflow-y: auto;
            color: var(--text-gray);
        }

        .sidebar.open {
            left: 0;
        }

        .sidebar__user-profile {
            padding: 25px 20px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            text-align: center;
        }

        .sidebar__user-name {
            color: var(--white);
            font-weight: bold;
            display: block;
            margin-bottom: 5px;
        }

        .sidebar__user-role {
            font-size: 0.8rem;
            color: var(--primary);
        }

        .sidebar__nav-group {
            padding: 20px 0 10px;
        }

        .sidebar__nav-label {
            padding: 0 20px 10px;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #555577;
            font-weight: bold;
        }

        .sidebar__item {
            display: flex;
            align-items: center;
            padding: 12px 20px;
            text-decoration: none;
            color: var(--text-gray);
            gap: 12px;
            transition: all 0.2s ease;
        }

        .sidebar__item:hover {
            color: var(--primary);
            background-color: var(--dark-light);
        }

        .sidebar__item--active {
            background-color: var(--primary);
            color: var(--white);
        }

        .sidebar__item--active:hover {
            color: var(--white);
        }

        /* Main Content Area */
        .main-wrapper {
            margin-top: var(--header-height);
            min-height: calc(100vh - var(--header-height));
            transition: margin-left 0.3s ease;
            width: 100%;
        }

        .main-content {
            padding: 25px;
            background-color: var(--white);
            min-height: calc(100vh - var(--header-height) - 60px);
        }

        /* Footer */
        .footer {
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #f5f5f5;
            border-top: 2px solid var(--primary);
            color: #666;
            font-size: 0.9rem;
        }

        .overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.5);
            z-index: 850;
            display: none;
        }

        .overlay.open {
            display: block;
        }

        /* Responsive */
        @media (min-width: 769px) {
            .header__hamburger {
                display: none;
            }

            .sidebar {
                left: 0;
            }

            .main-wrapper {
                margin-left: var(--sidebar-width);
                width: calc(100% - var(--sidebar-width));
            }

            .header__admin-info {
                display: flex;
            }

            .overlay {
                display: none !important;
            }
        }

        @RenderSection("Styles", required: false)
    </style>
</head>
<body>
    <header class="header">
        <div class="header__left">
            <div class="header__hamburger" id="adminSidebarToggle">☰</div>
            <div class="header__logo-text">CallMedical – Admin Panel</div>
        </div>
        <div class="header__right">
            <div class="header__admin-info">
                <div class="header__avatar">AD</div>
                <span>Administrator</span>
            </div>
            <div style="cursor: pointer;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
            </div>
            <button style="background: none; border: 1px solid var(--primary); color: var(--primary); padding: 5px 12px; border-radius: 4px; cursor: pointer;">Logout</button>
        </div>
    </header>

    <div class="overlay" id="adminOverlay"></div>

    <aside class="sidebar" id="adminSidebar">
        <div class="sidebar__user-profile">
            <span class="sidebar__user-name">Admin User</span>
            <span class="sidebar__user-role">System Administrator</span>
        </div>
        
        <div class="sidebar__nav-group">
            <div class="sidebar__nav-label">Overview</div>
            <a href="#" class="sidebar__item sidebar__item--active">
                <span>Dashboard</span>
            </a>
            <a href="#" class="sidebar__item">
                <span>Analytics</span>
            </a>
        </div>

        <div class="sidebar__nav-group">
            <div class="sidebar__nav-label">User Management</div>
            <a href="#" class="sidebar__item">
                <span>Users</span>
            </a>
            <a href="#" class="sidebar__item">
                <span>Doctors</span>
            </a>
            <a href="#" class="sidebar__item">
                <span>Patient Records</span>
            </a>
        </div>

        <div class="sidebar__nav-group">
            <div class="sidebar__nav-label">System</div>
            <a href="#" class="sidebar__item">
                <span>Appointments</span>
            </a>
            <a href="#" class="sidebar__item">
                <span>Content</span>
            </a>
            <a href="#" class="sidebar__item">
                <span>Settings</span>
            </a>
            <a href="#" class="sidebar__item">
                <span>Audit Logs</span>
            </a>
        </div>
    </aside>

    <div class="main-wrapper">
        <main class="main-content">
            @RenderBody()
        </main>
        <footer class="footer">
            &copy; @DateTime.Now.Year CallMedical Admin Panel. All rights reserved.
        </footer>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const toggle = document.getElementById('adminSidebarToggle');
            const sidebar = document.getElementById('adminSidebar');
            const overlay = document.getElementById('adminOverlay');

            function toggleSidebar() {
                sidebar.classList.toggle('open');
                overlay.classList.toggle('open');
                if (window.innerWidth <= 768) {
                    document.body.style.overflow = sidebar.classList.contains('open') ? 'hidden' : '';
                }
            }

            toggle.addEventListener('click', toggleSidebar);
            overlay.addEventListener('click', toggleSidebar);

            window.addEventListener('resize', () => {
                if (window.innerWidth > 768) {
                    sidebar.classList.remove('open');
                    overlay.classList.remove('open');
                    document.body.style.overflow = '';
                }
            });
        });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
