<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - CallMedical Expert Portal</title>
    <style>
        :root {
            --primary: #63B8FF;
            --white: #ffffff;
            --accent: #3A9EE8;
            --bg-light: #f8f9fa;
            --border-color: #e0e0e0;
            --text-dark: #333333;
            --text-muted: #666666;
            --sidebar-width: 240px;
            --header-height: 60px;
            --font-main: 'Inter', 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-main);
            background-color: var(--bg-light);
            color: var(--text-dark);
        }

        /* Header Styles */
        .header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: var(--header-height);
            background-color: var(--primary);
            color: var(--white);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
            z-index: 1000;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .header__left {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .header__hamburger {
            font-size: 1.5rem;
            cursor: pointer;
            display: block;
        }

        .header__logo-text {
            font-size: 1.25rem;
            font-weight: bold;
        }

        .header__right {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .header__user-info {
            display: none;
            align-items: center;
            gap: 10px;
        }

        .header__avatar {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            background-color: var(--white);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary);
            font-weight: bold;
        }

        .header__icon {
            cursor: pointer;
            position: relative;
        }

        .header__badge {
            position: absolute;
            top: -5px;
            right: -5px;
            background-color: #ff4d4d;
            color: white;
            font-size: 10px;
            padding: 2px 5px;
            border-radius: 10px;
        }

        /* Sidebar Styles */
        .sidebar {
            position: fixed;
            top: var(--header-height);
            left: -var(--sidebar-width);
            width: var(--sidebar-width);
            height: calc(100vh - var(--header-height));
            background-color: var(--white);
            border-right: 1px solid var(--border-color);
            transition: left 0.3s ease;
            z-index: 900;
            overflow-y: auto;
        }

        .sidebar.open {
            left: 0;
        }

        .sidebar__profile {
            padding: 20px;
            text-align: center;
            border-bottom: 1px solid var(--border-color);
        }

        .sidebar__profile-avatar {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background-color: #eee;
            margin: 0 auto 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .sidebar__profile-name {
            font-weight: bold;
            font-size: 1.1rem;
        }

        .sidebar__profile-specialty {
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        .sidebar__nav {
            padding: 10px 0;
        }

        .sidebar__item {
            display: flex;
            align-items: center;
            padding: 12px 20px;
            text-decoration: none;
            color: var(--text-dark);
            gap: 12px;
            transition: all 0.2s ease;
            border-left: 4px solid transparent;
        }

        .sidebar__item:hover {
            background-color: #f0f7ff;
            color: var(--primary);
        }

        .sidebar__item--active {
            background-color: var(--white);
            color: var(--primary);
            border-left: 4px solid var(--accent);
            font-weight: 600;
        }

        .sidebar__icon {
            width: 20px;
            height: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Main Content */
        .main-container {
            margin-top: var(--header-height);
            min-height: calc(100vh - var(--header-height));
            transition: margin-left 0.3s ease;
            width: 100%;
        }

        .main-content {
            padding: 20px;
        }

        /* Footer */
        .footer {
            padding: 20px;
            text-align: center;
            border-top: 1px solid var(--primary);
            color: var(--primary);
            font-size: 0.9rem;
            background-color: var(--white);
        }

        .overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.5);
            z-index: 850;
            display: none;
        }

        .overlay.open {
            display: block;
        }

        /* Responsive */
        @media (min-width: 769px) {
            .header__hamburger {
                display: none;
            }

            .sidebar {
                left: 0;
            }

            .main-container {
                margin-left: var(--sidebar-width);
                width: calc(100% - var(--sidebar-width));
            }

            .header__user-info {
                display: flex;
            }
            
            .overlay {
                display: none !important;
            }
        }

        @RenderSection("Styles", required: false)
    </style>
</head>
<body>
    <header class="header">
        <div class="header__left">
            <div class="header__hamburger" id="sidebarToggle">☰</div>
            <div class="header__logo-text">CallMedical – Doctor Portal</div>
        </div>
        <div class="header__right">
            <div class="header__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                <span class="header__badge">3</span>
            </div>
            <div class="header__user-info">
                <span>Dr. Nguyen Van A</span>
                <div class="header__avatar">NA</div>
            </div>
            <a href="#" style="color: white; text-decoration: none; font-size: 0.9rem; font-weight: 500;">Logout</a>
        </div>
    </header>

    <div class="overlay" id="overlay"></div>

    <aside class="sidebar" id="sidebar">
        <div class="sidebar__profile">
            <div class="sidebar__profile-avatar">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="#ccc"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
            </div>
            <div class="sidebar__profile-name">Dr. Nguyen Van A</div>
            <div class="sidebar__profile-specialty">Psychiatrist</div>
        </div>
        <nav class="sidebar__nav">
            <a href="#" class="sidebar__item sidebar__item--active">
                <span class="sidebar__icon">📊</span>
                <span>Dashboard</span>
            </a>
            <a href="#" class="sidebar__item">
                <span class="sidebar__icon">📅</span>
                <span>My Appointments</span>
            </a>
            <a href="#" class="sidebar__item">
                <span class="sidebar__icon">📁</span>
                <span>Patient Records</span>
            </a>
            <a href="#" class="sidebar__item">
                <span class="sidebar__icon">💬</span>
                <span>Messages</span>
            </a>
            <a href="#" class="sidebar__item">
                <span class="sidebar__icon">📋</span>
                <span>Health Reports</span>
            </a>
            <a href="#" class="sidebar__item">
                <span class="sidebar__icon">⚙️</span>
                <span>Settings</span>
            </a>
        </nav>
    </aside>

    <div class="main-container">
        <main class="main-content">
            @RenderBody()
        </main>
        <footer class="footer">
            &copy; 2025 CallMedical. All rights reserved.
        </footer>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const sidebarToggle = document.getElementById('sidebarToggle');
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('overlay');

            function toggleSidebar() {
                sidebar.classList.toggle('open');
                overlay.classList.toggle('open');
                if (window.innerWidth <= 768) {
                    document.body.style.overflow = sidebar.classList.contains('open') ? 'hidden' : '';
                }
            }

            sidebarToggle.addEventListener('click', toggleSidebar);
            overlay.addEventListener('click', toggleSidebar);

            // Close sidebar when clicking a link on mobile
            const sidebarLinks = document.querySelectorAll('.sidebar__item');
            sidebarLinks.forEach(link => {
                link.addEventListener('click', () => {
                    if (window.innerWidth <= 768) {
                        toggleSidebar();
                    }
                });
            });

            // Handle window resize
            window.addEventListener('resize', () => {
                if (window.innerWidth > 768) {
                    sidebar.classList.remove('open');
                    overlay.classList.remove('open');
                    document.body.style.overflow = '';
                }
            });
        });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
