@{
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
    ViewBag.Title = "Home - CallMedical";
}

<style>
    /* DESIGN SYSTEM & ROOT */
    :root {
        --primary: #63B8FF;
        --primary-dark: #1a6fc4;
        --white: #FFFFFF;
        --dark-text: #1a1a2e;
        --gray-text: #6b7280;
        --bg-light: #f0f8ff;
        --card-shadow: 0 4px 16px rgba(99,184,255,0.12);
        --radius: 12px;
        --transition: 0.3s ease;
    }

    /* GLOBAL ANIMATION CLASSES */
    .animate-in {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }

    .animate-in.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .section-padding {
        padding: 80px 5%;
    }

    .section-header {
        text-align: center;
        margin-bottom: 50px;
    }

    .section-title {
        font-size: 2.2rem;
        color: var(--dark-text);
        margin-bottom: 12px;
    }

    .section-subtitle {
        color: var(--gray-text);
        font-size: 1.1rem;
        max-width: 600px;
        margin: 0 auto;
    }

    /* SECTION 1: HERO BANNER */
    .hero {
        width: 100%;
        min-height: 480px;
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        display: flex;
        align-items: center;
        color: var(--white);
        padding: 0 5%;
        overflow: hidden;
    }

    .hero__content {
        display: flex;
        width: 100%;
        align-items: center;
        gap: 40px;
    }

    .hero__left {
        flex: 0 0 60%;
        animation: slideInLeft 0.8s ease-out forwards;
    }

    .hero__badge {
        display: inline-block;
        background: rgba(255, 255, 255, 0.2);
        padding: 6px 16px;
        border-radius: 50px;
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 20px;
    }

    .hero h1 {
        font-size: 3rem;
        line-height: 1.2;
        margin-bottom: 20px;
        font-weight: 800;
    }

    .hero__subtext {
        font-size: 1.2rem;
        opacity: 0.9;
        margin-bottom: 32px;
        max-width: 540px;
    }

    .hero__btns {
        display: flex;
        gap: 16px;
    }

    .btn-hero {
        padding: 14px 28px;
        border-radius: 8px;
        font-weight: 700;
        text-decoration: none;
        transition: var(--transition);
        display: inline-block;
    }

    .btn-hero--primary {
        background: var(--white);
        color: var(--primary);
    }

    .btn-hero--primary:hover {
        transform: scale(1.05);
        box-shadow: 0 8px 20px rgba(0,0,0,0.15);
    }

    .btn-hero--secondary {
        border: 2px solid var(--white);
        color: var(--white);
    }

    .btn-hero--secondary:hover {
        background: rgba(255,255,255,0.2);
    }

    .hero__right {
        flex: 0 0 40%;
        display: flex;
        justify-content: center;
    }

    .hero__illustration {
        width: 280px;
        height: 280px;
        background: rgba(255,255,255,0.15);
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 100px;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.3);
    }

    @@keyframes slideInLeft {
        from { opacity: 0; transform: translateX(-50px); }
        to { opacity: 1; transform: translateX(0); }
    }

    /* SECTION 2: FEATURE CARDS */
    .features-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
    }

    .feature-card {
        background: var(--white);
        padding: 40px 32px;
        border-radius: var(--radius);
        box-shadow: var(--card-shadow);
        transition: var(--transition);
        text-align: center;
    }

    .feature-card:hover {
        transform: translateY(-8px);
    }

    .feature-card__icon {
        width: 80px;
        height: 80px;
        background: #e8f4ff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        margin: 0 auto 24px;
    }

    .feature-card h3 {
        font-size: 1.5rem;
        margin-bottom: 16px;
        color: var(--dark-text);
    }

    .feature-card p {
        color: var(--gray-text);
        margin-bottom: 24px;
        line-height: 1.6;
    }

    .feature-card__link {
        color: var(--primary);
        text-decoration: none;
        font-weight: 700;
        transition: var(--transition);
    }

    .feature-card__link:hover {
        text-decoration: underline;
    }

    /* SECTION 3: STATISTICS BAR */
    .stats {
        background: var(--primary);
        padding: 60px 5%;
        color: var(--white);
    }

    .stats__grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        text-align: center;
    }

    .stat-item__number {
        font-size: 2.8rem;
        font-weight: 800;
        display: block;
        margin-bottom: 8px;
    }

    .stat-item__label {
        font-size: 1rem;
        opacity: 0.85;
    }

    /* SECTION 4: HOW IT WORKS */
    .steps-container {
        display: flex;
        justify-content: space-between;
        gap: 40px;
        position: relative;
    }

    .steps-container::before {
        content: '';
        position: absolute;
        top: 40px;
        left: 10%;
        right: 10%;
        height: 2px;
        border-top: 2px dashed var(--primary);
        z-index: 1;
        opacity: 0.3;
    }

    .step-item {
        flex: 1;
        text-align: center;
        position: relative;
        z-index: 2;
    }

    .step__number {
        width: 80px;
        height: 80px;
        background: var(--white);
        border: 4px solid var(--primary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--primary);
        margin: 0 auto 20px;
        transition: var(--transition);
    }

    .step-item:hover .step__number {
        background: var(--primary);
        color: var(--white);
    }

    .step__title {
        font-size: 1.3rem;
        font-weight: 700;
        margin-bottom: 12px;
        color: var(--dark-text);
    }

    .step__desc {
        color: var(--gray-text);
        font-size: 0.95rem;
        line-height: 1.5;
    }

    /* SECTION 5: FEATURED DOCTORS */
    .doctor-scroll {
        display: flex;
        gap: 24px;
        overflow-x: auto;
        padding: 20px 0 40px;
        scrollbar-width: none; /* Firefox */
    }

    .doctor-scroll::-webkit-scrollbar {
        display: none; /* Chrome/Safari */
    }

    .doctor-card {
        flex: 0 0 280px;
        background: var(--white);
        border-radius: var(--radius);
        padding: 32px 24px;
        box-shadow: var(--card-shadow);
        text-align: center;
        transition: var(--transition);
    }

    .doctor-card:hover {
        transform: translateY(-5px);
    }

    .doctor__avatar {
        width: 100px;
        height: 100px;
        background: #e8f4ff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        margin: 0 auto 20px;
    }

    .doctor__name {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--dark-text);
        margin-bottom: 4px;
    }

    .doctor__specialty {
        color: var(--primary);
        font-weight: 600;
        font-size: 0.9rem;
        margin-bottom: 8px;
    }

    .doctor__rating {
        color: #ffc107;
        margin-bottom: 8px;
    }

    .doctor__exp {
        font-size: 0.85rem;
        color: var(--gray-text);
        margin-bottom: 20px;
    }

    .btn-book {
        display: block;
        width: 100%;
        padding: 10px;
        background: var(--primary);
        color: var(--white);
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: var(--transition);
    }

    .btn-book:hover {
        background: var(--primary-dark);
    }

    /* SECTION 6: TESTIMONIALS */
    .testimonials {
        background: var(--bg-light);
    }

    .testimonials-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
    }

    .testimonial-card {
        background: var(--white);
        padding: 32px;
        border-radius: var(--radius);
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

    .testimonial__quote-icon {
        font-size: 40px;
        color: var(--primary);
        opacity: 0.3;
        margin-bottom: 10px;
        line-height: 1;
    }

    .testimonial__text {
        font-style: italic;
        color: var(--dark-text);
        line-height: 1.6;
        margin-bottom: 24px;
    }

    .testimonial__user {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .testimonial__avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: var(--primary);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
    }

    .testimonial__info h4 {
        font-size: 1rem;
        margin: 0;
    }

    .testimonial__info span {
        font-size: 0.85rem;
        color: var(--gray-text);
    }

    /* SECTION 7: CTA BANNER */
    .cta-banner {
        background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 100%);
        padding: 80px 5%;
        text-align: center;
        color: var(--white);
    }

    .cta-banner h2 {
        font-size: 2.5rem;
        margin-bottom: 16px;
    }

    .cta-banner p {
        font-size: 1.2rem;
        opacity: 0.9;
        margin-bottom: 40px;
    }

    .btn-large {
        padding: 18px 40px;
        background: var(--white);
        color: var(--primary);
        font-size: 1.2rem;
        font-weight: 800;
        border-radius: 50px;
        text-decoration: none;
        transition: var(--transition);
        display: inline-block;
    }

    .btn-large:hover {
        transform: scale(1.05);
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    /* RESPONSIVE MEDIA QUERIES */
    @@media (max-width: 1023px) {
        .features-grid, .testimonials-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        .stats__grid {
            grid-template-columns: repeat(2, 1fr);
        }
        .hero h1 { font-size: 2.5rem; }
    }

    @@media (max-width: 767px) {
        .hero { min-height: 320px; padding: 40px 5%; }
        .hero__content { flex-direction: column; text-align: center; }
        .hero__left { flex: 0 0 100%; }
        .hero__right { display: none; }
        .hero__subtext { margin-left: auto; margin-right: auto; }
        .hero__btns { justify-content: center; }

        .features-grid, .testimonials-grid { grid-template-columns: 1fr; }
        
        .steps-container { flex-direction: column; gap: 30px; }
        .steps-container::before { display: none; }

        .section-title { font-size: 1.8rem; }
        .cta-banner h2 { font-size: 1.8rem; }
    }

    @@media (max-width: 479px) {
        .hero__illustration { display: none; }
    }
</style>

