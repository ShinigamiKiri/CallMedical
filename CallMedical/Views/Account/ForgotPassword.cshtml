@{
    ViewBag.Title = "Quên mật khẩu";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<style>
    :root {
        --primary: #63B8FF;
        --primary-soft: #eef8ff;
        --bg-light: #F8FAFC;
        --dark-text: #0F172A;
        --card-shadow: 0 10px 40px rgba(99,184,255,0.1);
        --radius: 20px;
    }

    .auth-container {
        min-height: calc(100vh - 100px);
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: var(--bg-light);
        padding: 40px 20px;
    }

    .auth-card {
        background: white;
        padding: 40px;
        border-radius: var(--radius);
        box-shadow: var(--card-shadow);
        width: 100%;
        max-width: 450px;
        text-align: center;
    }

    .icon-box {
        width: 80px;
        height: 80px;
        background-color: var(--primary-soft);
        color: var(--primary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        margin: 0 auto 20px;
    }

    .auth-header h2 {
        color: var(--dark-text);
        font-weight: 700;
        margin-bottom: 10px;
    }

    .auth-header p {
        color: #64748B;
        font-size: 0.95rem;
        margin-bottom: 30px;
    }

    .form-group {
        text-align: left;
        margin-bottom: 20px;
    }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: var(--dark-text);
            font-size: 0.9rem;
        }

    .form-control {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #E2E8F0;
        border-radius: 12px;
        font-size: 1rem;
        transition: all 0.3s ease;
        max-width: none !important;
    }

        .form-control:focus {
            border-color: var(--primary);
            outline: none;
            box-shadow: 0 0 0 4px var(--primary-soft);
        }

    .btn-auth {
        width: 100%;
        padding: 14px;
        background-color: var(--primary);
        color: white;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .btn-auth:hover {
            background-color: #4A90E2;
            transform: translateY(-2px);
        }

    .back-to-login {
        display: inline-flex;
        align-items: center;
        margin-top: 25px;
        color: #64748B;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 600;
        transition: color 0.3s ease;
    }

        .back-to-login:hover {
            color: var(--primary);
        }

        .back-to-login i {
            margin-right: 8px;
        }

    #successMsg {
        display: none;
        background-color: #F0FDF4;
        color: #15803D;
        padding: 15px;
        border-radius: 12px;
        margin-bottom: 20px;
        font-size: 0.9rem;
    }
</style>

<div class="auth-container">
    <div class="auth-card">
        <div class="icon-box">
            <span>🔑</span>
        </div>
        <div class="auth-header">
            <h2>Quên mật khẩu?</h2>
            <p>Đừng lo lắng, hãy nhập email của bạn và chúng tôi sẽ gửi hướng dẫn đặt lại mật khẩu.</p>
        </div>

        <div id="successMsg">
            Chúng tôi đã gửi link đặt lại mật khẩu đến email của bạn. Vui lòng kiểm tra hộp thư.
        </div>

        <form id="forgotPasswordForm">
            <div class="form-group">
                <label for="Email">Địa chỉ Email</label>
                <input type="email" id="Email" class="form-control" placeholder="example@email.com" required>
            </div>

            <button type="submit" class="btn-auth" id="btnSubmit">Gửi yêu cầu</button>
        </form>

        <a href="@Url.Action("Login", "Account")" class="back-to-login">
            ← Quay lại đăng nhập
        </a>
    </div>
</div>

<script>
    document.getElementById('forgotPasswordForm').addEventListener('submit', async function (e) {
        e.preventDefault();

        const email = document.getElementById('Email').value;
        const btn = document.getElementById('btnSubmit');

        btn.disabled = true;
        btn.innerText = 'Đang xử lý...';

        try {
            const response = await fetch('/api/auth/forgot-password', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ email })
            });

            if (response.ok) {
                document.getElementById('forgotPasswordForm').style.display = 'none';
                document.getElementById('successMsg').style.display = 'block';
                document.querySelector('.auth-header p').style.display = 'none';
            } else {
                const data = await response.json();
                alert(data.message || 'Không tìm thấy tài khoản với email này.');
            }
        } catch (error) {
            console.error('Forgot password error:', error);
            alert('Đã có lỗi xảy ra. Vui lòng thử lại sau.');
        } finally {
            btn.disabled = false;
            btn.innerText = 'Gửi yêu cầu';
        }
    });
</script>
